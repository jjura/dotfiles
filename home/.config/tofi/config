#-------------------------------------------------------------------------------
# Background:
#-------------------------------------------------------------------------------
background-color = #000000

#-------------------------------------------------------------------------------
# Border:
#-------------------------------------------------------------------------------
border-color = #222222
border-width = 1
corner-radius = 0

#-------------------------------------------------------------------------------
# Font:
#-------------------------------------------------------------------------------
font = "local-monospace"
font-features = ""
font-size = 9
font-variations = ""
text-color = #555555

#-------------------------------------------------------------------------------
# Default:
#-------------------------------------------------------------------------------
default-result-background = #00000000
default-result-background-corner-radius = 0
default-result-background-padding = 0
# default-result-color = #FFFFFF

#-------------------------------------------------------------------------------
# Selection:
#-------------------------------------------------------------------------------
selection-background = #00000000
selection-background-corner-radius = 0
selection-background-padding = 0
selection-color = #888888
selection-match-color = #00000000

#-------------------------------------------------------------------------------
# Placeholder:
#-------------------------------------------------------------------------------
placeholder-background = #00000000
placeholder-background-corner-radius = 0
placeholder-background-padding = 0
# placeholder-color = #FFFFFF
placeholder-text = ""

#-------------------------------------------------------------------------------
# Prompt:
#-------------------------------------------------------------------------------
prompt-background = #00000000
prompt-background-corner-radius = 0
prompt-background-padding = 0
# prompt-color = #FFFFFF
prompt-padding = 0
prompt-text = ">"

#-------------------------------------------------------------------------------
# Input:
#-------------------------------------------------------------------------------
input-background = #00000000
input-background-corner-radius = 0
input-background-padding = 0
# input-color = #FFFFFF

#-------------------------------------------------------------------------------
# Margin:
#-------------------------------------------------------------------------------
margin-bottom = 10
margin-left = 10
margin-right = 10
margin-top = 10

#-------------------------------------------------------------------------------
# Outline:
#-------------------------------------------------------------------------------
outline-color = #FFFFFF
outline-width = 0

#-------------------------------------------------------------------------------
# Padding:
#-------------------------------------------------------------------------------
padding-bottom = 12
padding-left = 12
padding-right = 12
padding-top = 12

#-------------------------------------------------------------------------------
# Size:
#-------------------------------------------------------------------------------
height = 40
width = 480

#-------------------------------------------------------------------------------
# Position:
#-------------------------------------------------------------------------------
anchor = bottom
horizontal = true

#-------------------------------------------------------------------------------
# Match:
#-------------------------------------------------------------------------------
history = false
require-match = false
result-spacing = 10

#-------------------------------------------------------------------------------
# Hide:
#-------------------------------------------------------------------------------
hide-cursor = true
hide-input = true
hidden-character = ""

#-------------------------------------------------------------------------------
# Execution:
#-------------------------------------------------------------------------------
drun-launch = true
multi-instance = true
