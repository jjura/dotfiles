#-------------------------------------------------------------------------------
# Anchor:
#-------------------------------------------------------------------------------
anchor = bottom

#-------------------------------------------------------------------------------
# Background:
#-------------------------------------------------------------------------------
background-color = #141933

#-------------------------------------------------------------------------------
# Border:
#-------------------------------------------------------------------------------
border-color = #323f7f
border-width = 1

#-------------------------------------------------------------------------------
# Clip to padding:
#-------------------------------------------------------------------------------
clip-to-padding = false

#-------------------------------------------------------------------------------
# Drun launch:
#-------------------------------------------------------------------------------
drun-launch = true

#-------------------------------------------------------------------------------
# Font:
#-------------------------------------------------------------------------------
font = interface
font-size = 9

#-------------------------------------------------------------------------------
# Height:
#-------------------------------------------------------------------------------
height = 40

#-------------------------------------------------------------------------------
# Hide input:
#-------------------------------------------------------------------------------
hide-input = true

#-------------------------------------------------------------------------------
# History:
#-------------------------------------------------------------------------------
history = false

#-------------------------------------------------------------------------------
# Horizontal:
#-------------------------------------------------------------------------------
horizontal = true

#-------------------------------------------------------------------------------
# Margin:
#-------------------------------------------------------------------------------
margin-bottom = 8
margin-left = 0
margin-right = 0
margin-top = 0

#-------------------------------------------------------------------------------
# Outline:
#-------------------------------------------------------------------------------
outline-width = 0

#-------------------------------------------------------------------------------
# Output:
#-------------------------------------------------------------------------------
output = DP-2

#-------------------------------------------------------------------------------
# Padding:
#-------------------------------------------------------------------------------
padding-bottom = 12
padding-left = 12
padding-right = 12
padding-top = 12

#-------------------------------------------------------------------------------
# Prompt:
#-------------------------------------------------------------------------------
prompt-background = #000000
prompt-background-padding = 12,12,13,12
prompt-padding = 12

#-------------------------------------------------------------------------------
# Result:
#-------------------------------------------------------------------------------
result-spacing = 12

#-------------------------------------------------------------------------------
# Selection:
#-------------------------------------------------------------------------------
selection-color = #ff7f94

#-------------------------------------------------------------------------------
# Text:
#-------------------------------------------------------------------------------
text-color = #6677cc

#-------------------------------------------------------------------------------
# Width:
#-------------------------------------------------------------------------------
width = 480
