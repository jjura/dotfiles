#!/bin/bash

CONTAINER_MOUNT_DIRS=("/proc" "/dev" "/sys")
CONTAINERS_DIR=/home/$SUDO_USER/Containers

# Check if the script is called as root or using sudo
if [[ $(id -u) != 0 ]]; then
    echo "Error: The script must be run as root or with sudo!"
    exit
fi

# Create the containers directory for the calling user
if [[ ! -d $CONTAINERS_DIR ]]; then
    echo "Container: Creating containers directory: $CONTAINERS_DIR"
    mkdir -p $CONTAINERS_DIR
fi

# Check what options is being called
if [[ -z $1 ]]; then
    # Available options
    echo "Error: $(basename $0) [create, list, mount, umount, enter]"
elif [[ $1 == "create" ]]; then
    # Creating container
    if [[ -z $2 || -z $3 || -z $4 ]]; then
        echo "Error: $(basename $0) $1 <arch> <version> <name>"
    else
        CONTAINER_DIR=${CONTAINERS_DIR}/$4

        echo "Creating container: $(basename $CONTAINER_DIR)"
        debootstrap --variant=minbase --arch=$2 $3 $CONTAINER_DIR
    fi
elif [[ $1 == "list" ]]; then
    # Listing available containers
    for CONTAINER_DIR in $CONTAINERS_DIR/*; do
        if [[ -d $CONTAINER_DIR ]]; then
            echo "Container: $(basename $CONTAINER_DIR)"
        fi
    done
elif [[ $1 == "mount" ]]; then
    # Mounting all resources to the container
    if [[ -z $2 ]]; then
        echo "Error: $(basename $0) $1 <name>"
    else
        CONTAINER_DIR=$CONTAINERS_DIR/$2

        if [[ ! -d $CONTAINER_DIR ]]; then
            echo "Error: Container $(basename $CONTAINER_DIR) does not exist."
        else
            for CONTAINER_MOUNT_DIR in ${CONTAINER_MOUNT_DIRS[@]}; do
                CONTAINER_MOUNT_DEST_DIR=${CONTAINER_DIR}${CONTAINER_MOUNT_DIR}
                mountpoint -q $CONTAINER_MOUNT_DEST_DIR
                CONTAINER_MOUNT_DEST_DIR_STATUS=$?

                if [[ $CONTAINER_MOUNT_DEST_DIR_STATUS -eq 0 ]]; then
                    echo "Skipping $CONTAINER_MOUNT_DEST_DIR since it's already mounted."
                else
                    mount --rbind $CONTAINER_MOUNT_DIR $CONTAINER_MOUNT_DEST_DIR
                    mount --make-rslave $CONTAINER_MOUNT_DEST_DIR
                    echo "Mounting $CONTAINER_MOUNT_DIR in $CONTAINER_MOUNT_DEST_DIR"
                fi
            done
            xhost +local:
        fi
    fi
elif [[ $1 == "umount" ]]; then
    # Unmounting all resources from the container
    if [[ -z $2 ]]; then
        echo "Error: $(basename $0) $1 <name>"
    else
        CONTAINER_DIR=$CONTAINERS_DIR/$2

        if [[ ! -d $CONTAINER_DIR ]]; then
            echo "Error: Container $(basename $CONTAINER_DIR) does not exist."
        else
            for CONTAINER_UMOUNT_DIR in ${CONTAINER_MOUNT_DIRS[@]}; do
                CONTAINER_UMOUNT_DEST_DIR=${CONTAINER_DIR}${CONTAINER_UMOUNT_DIR}
                mountpoint -q $CONTAINER_UMOUNT_DEST_DIR
                CONTAINER_UMOUNT_DEST_DIR_STATUS=$?

                if [[ $CONTAINER_UMOUNT_DEST_DIR_STATUS -eq 0 ]]; then
                    echo "Umounting $CONTAINER_UMOUNT_DIR in $CONTAINER_UMOUNT_DEST_DIR"
                    umount -R $CONTAINER_UMOUNT_DEST_DIR
                else
                    echo "Skipping $CONTAINER_UMOUNT_DEST_DIR since it's not mounted."
                fi
            done
            xhost -local:
        fi
    fi
elif [[ $1 == "enter" ]]; then
    # Entering the container
    if [[ -z $2 || -z $3 ]]; then
        echo "Error: $(basename $0) $1 <name> <user>"
    else
        CONTAINER_DIR=$CONTAINERS_DIR/$2

        if [[ ! -d $CONTAINER_DIR ]]; then
            echo "Error: Container $(basename $CONTAINER_DIR) does not exist."
        else
            chroot $CONTAINER_DIR /bin/bash -c "su $3"
        fi
    fi
elif [[ $1 == "exec" ]]; then
    # Execute the passed command as a user on the container
    if [[ -z $2 || -z $3 || -z $4 ]]; then
        echo "Error: $(basename $0) $1 <name> <user> <command>"
    else
        CONTAINER_DIR=$CONTAINERS_DIR/$2

        if [[ ! -d $CONTAINER_DIR ]]; then
            echo "Error: Container $(basename $CONTAINER_DIR) does not exist."
        else
            chroot $CONTAINER_DIR /bin/bash << EOT
su $3
$4
EOT
        fi
    fi
else
    echo "Error: Option $1 is not valid."
fi
