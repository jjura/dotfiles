#!/bin/bash

#-------------------------------------------------------------------------------
# Init
#-------------------------------------------------------------------------------
APP_DIR="/home/$SUDO_USER/Containers"
APP_TMP_DIR="$APP_DIR/.tmp"

# Check if script is called as a sudo user.
if [ -z $SUDO_USER ]; then
        echo "Error: $(basename $0) must be called as a sudo user!"
        exit
fi

# Check if the container directory exists.
if [ ! -d $APP_DIR ]; then
        echo "Error: The specified directory '$APP_DIR' doesn't exist!"
        exit
fi

#-------------------------------------------------------------------------------
# Debootstrap
#-------------------------------------------------------------------------------
DEBOOTSTRAP_URL="http://deb.debian.org/debian/pool/main/d/debootstrap/debootstrap_1.0.123.tar.gz"
DEBOOTSTRAP_DIR="$APP_DIR/debootstrap"
DEBOOTSTRAP_ARCHIVE="$APP_DIR/$(basename $DEBOOTSTRAP_URL)"

# Check if the debootstrap is already prepared.
if [ ! -d $DEBOOTSTRAP_DIR ]; then
        # Download debootstrap archive.
        if [ ! -f $DEBOOTSTRAP_ARCHIVE ]; then
                wget --quiet $DEBOOTSTRAP_URL -O $DEBOOTSTRAP_ARCHIVE
        fi

        # Extract debootstrap.
        if [ -f $DEBOOTSTRA_ARCHIVE ]; then
                tar xf $DEBOOTSTRAP_ARCHIVE -C $APP_DIR
                rm $DEBOOTSTRAP_ARCHIVE
        fi
fi

#-------------------------------------------------------------------------------
# Base
#-------------------------------------------------------------------------------
BASE_ARCH="amd64"
BASE_VARIANT="minbase"
BASE_RELEASE="testing"
BASE_PACKAGES="systemd-sysv,dbus"
BASE_DIR="$APP_DIR/$BASE_RELEASE-$BASE_VARIANT-$BASE_ARCH"

# Check if the base is already downloaded.
if [ ! -d $BASE_DIR ]; then
        # Download the base.
        DEBOOTSTRAP_DIR=$DEBOOTSTRAP_DIR $DEBOOTSTRAP_DIR/debootstrap \
                --include $BASE_PACKAGES \
                --variant $BASE_VARIANT \
                --arch $BASE_ARCH \
                $BASE_RELEASE $BASE_DIR
fi

#-------------------------------------------------------------------------------
# Command: create <container>
#-------------------------------------------------------------------------------
if [ "$1" = "create" ]; then
        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "Error: $(basename $0) create <container>"
                exit
        fi

        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_DIR/$CONTAINER_NAME"

        # Check if the container directory exists.
        if [ -d $CONTAINER_DIR ]; then
                echo "Error: Container '$CONTAINER_NAME' already exists!"
                exit
        fi

        # Create container configuration directory.
        mkdir -p $CONTAINER_DIR/etc/systemd/network

        # Configure the hostname.
        echo -e "127.0.0.1 localhost\n127.0.0.1 $CONTAINER_NAME" \
                > $CONTAINER_DIR/etc/hosts

        echo -e "$CONTAINER_NAME" \
                > $CONTAINER_DIR/etc/hostname

        # Configure the environment variables.
        echo -e "export DISPLAY=:0\nexport TERM=xterm-256color" \
                > $CONTAINER_DIR/etc/environment

        # Configure the selected audio card and device.
        echo -e "defaults.pcm.card 0\ndefaults.pcm.device 1" \
                > $CONTAINER_DIR/etc/asound.conf

        # Configure the host0 virtual network card.
        echo -e "[Match]\nName=host0\n[Network]\nDHCP=yes" \
                > $CONTAINER_DIR/etc/systemd/network/20-wired.network

        # Notify user about successful creation.
        echo "Info: Container '$CONTAINER_NAME' created."

#-------------------------------------------------------------------------------
# Command: remove <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "remove" ]; then
        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "Error: $(basename $0) remove <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_DIR/$CONTAINER_NAME"
        CONTAINER_TMP_DIR="$APP_TMP_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "Error: Container '$CONTAINER_NAME' doesn't exist!"
                exit;
        fi

        # Check if the container isn't mounted.
        CONTAINER_MOUNT_DIR="$CONTAINER_TMP_DIR/mount"

        mountpoint -q $CONTAINER_MOUNT_DIR
        if [ $? -eq 0 ]; then
                echo "Error: Container '$CONTAINER_NAME' is mounted!"
                exit
        fi

        # Remove the container and it's temporary directory.
        rm -rf $CONTAINER_DIR
        rm -rf $CONTAINER_TMP_DIR

        # Notify user about successful removal.
        echo "Info: Container '$CONTAINER_NAME' removed."

#-------------------------------------------------------------------------------
# Command: mount <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "mount" ]; then
        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "Error: $(basename $0) mount <container>"
                exit
        fi
        
        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_DIR/$CONTAINER_NAME"
        CONTAINER_TMP_DIR="$APP_TMP_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "Error: Container '$CONTAINER_NAME' doesn't exist!"
                exit;
        fi

        # Check if the container isn't mounted.
        CONTAINER_WORK_DIR="$CONTAINER_TMP_DIR/work"
        CONTAINER_MOUNT_DIR="$CONTAINER_TMP_DIR/mount"

        mountpoint -q $CONTAINER_MOUNT_DIR
        if [ $? -eq 0 ]; then
                echo "Info: Container '$CONTAINER_NAME' is already mounted."
                exit
        fi

        # Create the container temporary directories.
        mkdir -p $CONTAINER_MOUNT_DIR $CONTAINER_WORK_DIR
        
        # Mount the container using overlayfs.
        mount -t overlay overlay -o lowerdir=$BASE_DIR,upperdir=$CONTAINER_DIR,workdir=$CONTAINER_WORK_DIR $CONTAINER_MOUNT_DIR

        # Enable remote access to the X11 server.
        xhost +local: > /dev/null

        # Notify user about successful mount.
        echo "Info: Container '$CONTAINER_NAME' mounted."

#-------------------------------------------------------------------------------
# Command: umount <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "umount" ]; then
        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "Error: $(basename $0) umount <container>"
                exit
        fi
        
        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_DIR/$CONTAINER_NAME"
        CONTAINER_TMP_DIR="$APP_TMP_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "Error: Container '$CONTAINER_NAME' doesn't exist!"
                exit;
        fi

        # Check if the container isn't mounted.
        CONTAINER_MOUNT_DIR="$CONTAINER_TMP_DIR/mount"

        mountpoint -q $CONTAINER_MOUNT_DIR
        if [ $? -ne 0 ]; then
                echo "Info: Container '$CONTAINER_NAME' is not mounted."
                exit
        fi

        # Unmount the container.
        umount -R $CONTAINER_MOUNT_DIR

        # Disable remote access to the X11 server.
        xhost -local: > /dev/null

        # Notify user about successful unmount.
        echo "Info: Container '$CONTAINER_NAME' unmounted."

#-------------------------------------------------------------------------------
# Command: enter
#-------------------------------------------------------------------------------
elif [ "$1" = "enter" ]; then
        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "Error: $(basename $0) enter <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_DIR/$CONTAINER_NAME"
        CONTAINER_TMP_DIR="$APP_TMP_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "Error: Container '$CONTAINER_NAME' doesn't exist!"
                exit;
        fi

        # Check if the container isn't mounted.
        CONTAINER_MOUNT_DIR="$CONTAINER_TMP_DIR/mount"

        mountpoint -q $CONTAINER_MOUNT_DIR
        if [ $? -ne 0 ]; then
                echo "Info: Container '$CONTAINER_NAME' is not mounted."
                exit
        fi

        # Enter the container.
        systemd-nspawn \
                --boot \
                --network-veth \
                --bind /dev/dri \
                --bind /dev/snd \
                --bind-ro /tmp/.X11-unix/X0 \
                --property DeviceAllow="char-alsa rwm" \
                --directory $CONTAINER_MOUNT_DIR \
                --machine $CONTAINER_NAME

#-------------------------------------------------------------------------------
# Command: help
#-------------------------------------------------------------------------------
elif [ "$1" = "--help" ]; then
        echo -e "Usage: $(basename $0) <command> <container>"
        echo -e "Commands:"
        echo -e "\tcreate\t- creates new container of specified name."
        echo -e "\tremove\t- removes entire container along with its files."
        echo -e "\tmount\t- mounts the specified container on top of the base."
        echo -e "\tumount\t- umount the specified container."
        echo -e "\tenter\t- boots and enters the specified container."
else
        echo -e "Info: $(basename $0) <command> <container>"
#-------------------------------------------------------------------------------
fi
