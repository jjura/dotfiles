#!/bin/bash

BASE_DIR="/home/$SUDO_USER/Containers"
BASE_LOWER_DIR="$BASE_DIR/lower"
BASE_UPPER_DIR="$BASE_DIR/upper"
BASE_MOUNT_DIR="$BASE_DIR/.containerctl"
BASE_TOOLS_DIR="$(dirname $0)/tools"
BASE_PACKAGES="systemd,dbus,sudo"

#------------------------------------------------------------------------------#
if [ $(id -u) -ne 0 ] || [ -z $SUDO_USER ]; then
        echo "Error: This program must be run using sudo!"
#------------------------------------------------------------------------------#
elif [ "$1" = "list" ]; then
        # Printing the upper container layers
        echo "+---------------------------------------------------------------+"
        echo "| UPPER                                                         |"
        echo "+---------------------------------------------------------------+"
        DIRS=$(find $BASE_UPPER_DIR -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
        for DIR in $DIRS; do
                mountpoint -q $BASE_MOUNT_DIR/$(basename $DIR)

                if [ $? -eq 0 ]; then
                        echo "- $(basename $DIR) (mounted)"
                else
                        echo "- $(basename $DIR)"
                fi
        done
        # Printing the lower container layers
        echo "+---------------------------------------------------------------+"
        echo "| LOWER                                                         |"
        echo "+---------------------------------------------------------------+"
        DIRS=$(find $BASE_LOWER_DIR -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
        for DIR in $DIRS; do
                echo "- $(basename $DIR)"
        done
#------------------------------------------------------------------------------#
elif [ "$1" = "create" ]; then
        #----------------------------------------------------------------------#
        if [ "$2" = "lower" ]; then
                # Checking the number of passed arguments
                if [ $# -eq 4 ]; then
                        LOWER_RELEASE="$4"
                        LOWER_NAME="$3-$LOWER_RELEASE"
                        LOWER_DIR="$BASE_LOWER_DIR/$LOWER_NAME"

                        # Checking if the lowers dir exist
                        if [ ! -d $BASE_LOWER_DIR ]; then
                                mkdir -p $BASE_LOWER_DIR
                        fi

                        # Checking if the specified lower doesn't already exist
                        if [ ! -d $LOWER_DIR ]; then
                                echo "Info: Creating a lower layer '$LOWER_NAME'"

                                # Downloading packages for specified base
                                DEBOOTSTRAP_DIR=$BASE_TOOLS_DIR $BASE_TOOLS_DIR/debootstrap \
                                        --include=$BASE_PACKAGES \
                                        --variant="minbase" \
                                        --arch="amd64" \
                                        $LOWER_RELEASE $LOWER_DIR

                                # Configuring the lower layer environment
                                echo -e "127.0.0.1 localhost\n127.0.0.1 $(hostname)" > \
                                        $LOWER_DIR/etc/hosts
                                echo -e "export DISPLAY=:0\nexport TERM=xterm-256color" > \
                                        $LOWER_DIR/etc/environment
                                echo -e "defaults.pcm.card 0\ndefaults.pcm.device 1" > \
                                        $LOWER_DIR/etc/asound.conf
                                echo -e "[Match]\nName=host0\n[Network]\nDHCP=y" > \
                                        $LOWER_DIR/etc/systemd/network/20-wired.network
                        else
                                echo "Error: Specified lower '$LOWER_NAME' already exists!"
                        fi
                else
                        echo "Error: $0 create lower <name> <release>"
                fi
        #----------------------------------------------------------------------#
        elif [ "$2" = "upper" ]; then
                # Checking the number of passed arguments
                if [ $# -eq 3 ]; then
                        UPPER_NAME="$3"
                        UPPER_DIR="$BASE_UPPER_DIR/$UPPER_NAME"

                        # Checking if the uppers dir exist
                        if [ ! -d $BASE_UPPER_DIR ]; then
                                mkdir -p $BASE_UPPER_DIR
                        fi

                        # Checking if the specified upper doesn't already exist
                        if [ ! -d $UPPER_DIR ]; then
                                # Configuring the upper layer identity
                                UPPER_CHROOT_FILE="$UPPER_DIR/etc/debian_chroot"

                                mkdir -p $(dirname $UPPER_CHROOT_FILE)
                                echo $UPPER_NAME > $UPPER_CHROOT_FILE

                                echo "Info: Creating an upper layer '$UPPER_NAME'"
                        else
                                echo "Error: Specified upper '$UPPER_NAME' already exists!"
                        fi
                else
                        echo "Error: $0 create upper <name>"
                fi
        #----------------------------------------------------------------------#
        else
                echo "Error: $0 create <upper, lower>"
        fi
#------------------------------------------------------------------------------#
elif [ "$1" = "mount" ]; then
        # Checking the number of passed arguments
        if [ $# -eq 3 ]; then
                LOWER_NAME="$2"
                LOWER_DIR="$BASE_LOWER_DIR/$LOWER_NAME"
                UPPER_NAME="$3"
                UPPER_DIR="$BASE_UPPER_DIR/$UPPER_NAME"

                # Checking the existence of lower and upper directory
                if [ ! -d $LOWER_DIR ] || [ ! -d $UPPER_DIR ]; then
                        echo "Error: Specified upper or lower doesn't exist!"
                else
                        UPPER_MOUNT_DIR="$BASE_MOUNT_DIR/$UPPER_NAME"
                        mountpoint -q $UPPER_MOUNT_DIR

                        # Checking if the mount directory isn't mounted
                        if [ ! $? -eq 0 ]; then
                                WORKS_DIR="$BASE_MOUNT_DIR/.tmp"

                                # Checking if the mount directory exists
                                if [ ! -d $UPPER_MOUNT_DIR ]; then
                                        mkdir -p $UPPER_MOUNT_DIR
                                fi

                                # Checking if the work directory exists
                                if [ ! -d $WORKS_DIR ]; then
                                        mkdir -p $WORKS_DIR
                                fi

                                # Constructing the rootfs using the overlay
                                mount -t overlay overlay -o lowerdir=$LOWER_DIR,upperdir=$UPPER_DIR,workdir=$WORKS_DIR $UPPER_MOUNT_DIR

                                # Enabling the access to the X11 server
                                xhost +local:
                        else
                                echo "Error: The mount directory '$UPPER_MOUNT_DIR' is already mounted!"
                        fi
                fi
        else
                echo "Error: $0 mount <lower> <upper>"
        fi
#------------------------------------------------------------------------------#
elif [ "$1" = "umount" ]; then
        # Checking the number of passed arguments
        if [ $# -eq 2 ]; then
                UPPER_NAME="$2"

                # Checking the existance of upper directory
                if [ -d $BASE_UPPER_DIR/$UPPER_NAME ]; then
                        UPPER_MOUNT_DIR="$BASE_MOUNT_DIR/$UPPER_NAME"

                        # Checking if the mount directory is mounted
                        mountpoint -q $UPPER_MOUNT_DIR

                        if [ $? -eq 0 ]; then
                                # Unmounting the overlay rootfs
                                umount -R $UPPER_MOUNT_DIR

                                # Disabling the access to the X11 server
                                xhost -local:
                        else
                                echo "Error: The specified upper '$UPPER_NAME' isn't mounted!"
                        fi
                else
                        echo "Error: The specified upper '$UPPER_NAME' doesn't exist!"
                fi
        else
                echo "Error: $0 umount <upper>"
        fi
#------------------------------------------------------------------------------#
elif [ "$1" = "enter" ]; then
        # Specifying the entry user
        if [ ! -z $3 ]; then
                USER=$3;
        else
                USER="root"
        fi

        # Checking the number of passed arguments
        if [ $# -eq 2 ] || [ $# -eq 3 ]; then
                UPPER_NAME="$2"

                # Checking the existance of upper directory
                if [ -d $BASE_UPPER_DIR/$UPPER_NAME ]; then
                        UPPER_MOUNT_DIR="$BASE_MOUNT_DIR/$UPPER_NAME"

                        # Checking if the mount directory is mounted
                        mountpoint -q $UPPER_MOUNT_DIR

                        if [ $? -eq 0 ]; then
                                systemd-nspawn \
                                        --boot \
                                        --network-veth \
                                        --bind /dev/dri \
                                        --bind /dev/snd \
                                        --property=DeviceAllow="char-alsa rwm" \
                                        --bind-ro /tmp/.X11-unix/X0 \
                                        --directory $UPPER_MOUNT_DIR
                        else
                                echo "Error: The specified upper '$UPPER_NAME' isn't mounted!"
                        fi
                else
                        echo "Error: The specified upper '$UPPER_NAME' doesn't exist!"
                fi
        else
                echo "Error: $0 enter <mounted> [user=root]"
        fi
#------------------------------------------------------------------------------#
else
        echo "$0 <list, create, mount, umount, enter>"
#------------------------------------------------------------------------------#
fi
