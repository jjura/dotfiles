#!/bin/bash

# Directory to be set by user.
APP_DIR="/usr/local/share/containerctl"

# Container structure.
DIR_ROOTFS="rootfs"
DIR_MOUNT="mount"
DIR_WORK="work"
DIR_BASE="base"

# Application structure.
DIR_CONTAINERS="containers"
DIR_BASES="bases"
DIR_TOOLS="tools"

# Colors
COLOR_GRAY="\033[1;30m"
COLOR_GREEN="\033[1;32m"
COLOR_YELLOW="\033[1;33m"
COLOR_DEFAULT="\033[0m"

# Global paths.
APP_CONTAINERS_DIR="$APP_DIR/$DIR_CONTAINERS"
APP_BASES_DIR="$APP_DIR/$DIR_BASES"
APP_TOOLS_DIR="$APP_DIR/$DIR_TOOLS"

#-------------------------------------------------------------------------------
# Initialize
#-------------------------------------------------------------------------------

# Check if script is called as a sudo user.
if [ -z $SUDO_USER ]; then
        echo "$(basename $0): must be called as a sudo user."
        exit
fi

# Check if the application directory exists.
if [ ! -d $APP_DIR ]; then
        echo "$(basename $0): initializing the application directory."
        mkdir -p $APP_DIR \
                 $APP_TOOLS_DIR \
                 $APP_BASES_DIR \
                 $APP_CONTAINERS_DIR
fi

#-------------------------------------------------------------------------------
# Debootstrap
#-------------------------------------------------------------------------------
DEBOOTSTRAP_URL="http://deb.debian.org/debian/pool/main/d/debootstrap/debootstrap_1.0.123.tar.gz"
DEBOOTSTRAP_DIR="$APP_TOOLS_DIR/debootstrap"
DEBOOTSTRAP_ARCHIVE="$APP_TOOLS_DIR/$(basename $DEBOOTSTRAP_URL)"

# Check if the debootstrap is already prepared.
if [ ! -d $DEBOOTSTRAP_DIR ]; then

        # Download debootstrap archive.
        if [ ! -f $DEBOOTSTRAP_ARCHIVE ]; then
                wget --quiet $DEBOOTSTRAP_URL -O $DEBOOTSTRAP_ARCHIVE
        fi

        # Extract debootstrap.
        if [ -f $DEBOOTSTRA_ARCHIVE ]; then
                tar xf $DEBOOTSTRAP_ARCHIVE -C $APP_TOOLS_DIR
                rm $DEBOOTSTRAP_ARCHIVE
        fi
fi

#-------------------------------------------------------------------------------
# command: list
#-------------------------------------------------------------------------------
if [ "$1" = "list" ] || [ -z "$1" ]; then

        echo "-----------------------------------------------------------------"
        echo "CONTAINERS:"
        echo "-----------------------------------------------------------------"
        for DIRECTORY in $(find $APP_CONTAINERS_DIR -mindepth 1 -maxdepth 1 -type d); do
                CONTAINER_NAME="$(basename $DIRECTORY)"
                CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"
                CONTAINER_BASE="$(basename $(readlink -f $CONTAINER_DIR/$DIR_BASE))"

                unset CONTAINER_BOOTED
                unset CONTAINER_MOUNTED

                # Check if the container is booted up.
                machinectl --quiet show $CONTAINER_NAME > /dev/null 2>&1

                if [ $? -eq 0 ]; then
                        CONTAINER_BOOTED="${COLOR_GREEN}booted${COLOR_DEFAULT}"
                fi

                # Check if the container is mounted.
                mountpoint -q $CONTAINER_DIR/$DIR_MOUNT

                if [ $? -eq 0 ]; then
                        CONTAINER_MOUNTED="${COLOR_YELLOW}mounted${COLOR_DEFAULT}"
                fi

                echo -e "- $CONTAINER_NAME ($COLOR_GRAY$CONTAINER_BASE$COLOR_DEFAULT)" \
                        "$CONTAINER_MOUNTED $CONTAINER_BOOTED"
        done

        echo "-----------------------------------------------------------------"
        echo "BASES:"
        echo "-----------------------------------------------------------------"
        for DIRECTORY in $(find $APP_BASES_DIR -mindepth 1 -maxdepth 1 -type d); do
                echo "- $(basename $DIRECTORY)"
        done

#-------------------------------------------------------------------------------
# command: download <arch> <variant> <release>
#-------------------------------------------------------------------------------
elif [ "$1" = "download" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 4 ]; then
                echo "$(basename $0): download <arch> <variant> <release>"
                exit
        fi

        # Check if the base does not already exist.
        BASE_ARCH="$2"
        BASE_VARIANT="$3"
        BASE_RELEASE="$4"
        BASE_PACKAGES="systemd-sysv,dbus"
        BASE_DIR="$APP_BASES_DIR/$BASE_ARCH-$BASE_RELEASE-$BASE_VARIANT"

        if [ -d $BASE_DIR ]; then
                echo "$(basename $0): specified base already exists."
                exit
        fi

        # Download the base.
        DEBOOTSTRAP_DIR=$DEBOOTSTRAP_DIR $DEBOOTSTRAP_DIR/debootstrap \
                --include $BASE_PACKAGES \
                --variant $BASE_VARIANT \
                --arch    $BASE_ARCH \
                $BASE_RELEASE $BASE_DIR

#-------------------------------------------------------------------------------
# command: update <base>
#-------------------------------------------------------------------------------
elif [ "$1" = "update" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "$(basename $0): update <base>"
                exit
        fi

        # Check if the base directory exists.
        CONTAINER_BASE_NAME="$2"
        CONTAINER_BASE_DIR="$APP_BASES_DIR/$CONTAINER_BASE_NAME"

        if [ ! -d $CONTAINER_BASE_DIR ]; then
                echo "$(basename $0): specified base does not exist."
                exit
        fi

        # Enter the base and update it.
        systemd-nspawn --directory $CONTAINER_BASE_DIR --pipe /bin/bash <<- EOF
		apt-get update
		apt-get dist-upgrade -y
		apt-get clean
		EOF

#-------------------------------------------------------------------------------
# command: create <base> <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "create" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 3 ]; then
                echo "$(basename $0): create <base> <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$3"
        CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"

        if [ -d $CONTAINER_DIR ]; then
                echo "$(basename $0): specified container already exists."
                exit
        fi

        # Check if the base directory exists.
        CONTAINER_BASE_NAME="$2"
        CONTAINER_BASE_DIR="$APP_BASES_DIR/$CONTAINER_BASE_NAME"

        if [ ! -d $CONTAINER_BASE_DIR ]; then
                echo "$(basename $0): specified base does not exist."
                exit
        fi

        # Create container structure directory.
        mkdir -p $CONTAINER_DIR \
                 $CONTAINER_DIR/$DIR_ROOTFS \
                 $CONTAINER_DIR/$DIR_MOUNT \
                 $CONTAINER_DIR/$DIR_WORK

        # Create a link to the base directory.
        ln -s $CONTAINER_BASE_DIR $CONTAINER_DIR/$DIR_BASE

        # Mount the container on top of its base.
        mount -t overlay overlay \
              -o lowerdir=$CONTAINER_DIR/$DIR_BASE,upperdir=$CONTAINER_DIR/$DIR_ROOTFS,workdir=$CONTAINER_DIR/$DIR_WORK \
              $CONTAINER_DIR/$DIR_MOUNT

        # Configure the container.
        systemd-nspawn --directory $CONTAINER_DIR/$DIR_MOUNT --pipe /bin/bash <<- EOF
		mkdir -p /etc/systemd/network

		echo -e "$CONTAINER_NAME" \
			> /etc/hostname
		echo -e "127.0.0.1 localhost\n127.0.0.1 $CONTAINER_NAME" \
			> /etc/hosts
		echo -e "export DISPLAY=:0\nexport TERM=xterm-256color" \
			> /etc/environment
		echo -e "defaults.pcm.card 0\ndefaults.pcm.device 1" \
			> /etc/asound.conf
		echo -e "[Match]\nName=host0\n[Network]\nDHCP=yes" \
			> /etc/systemd/network/20-wired.network

		echo -e "root\nroot" | passwd root

		systemctl enable systemd-networkd
		systemctl enable systemd-resolved
		EOF

        # Umount the container.
        umount -R $CONTAINER_DIR/$DIR_MOUNT

        # Notify user about successful creation.
        echo "$(basename $0): specified container created."

#-------------------------------------------------------------------------------
# command: destroy <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "destroy" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "$(basename $0): destroy <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "$(basename $0): specified container does not exist."
                exit
        fi

        # Check if the container is mounted.
        mountpoint -q $CONTAINER_DIR/$DIR_MOUNT

        if [ $? -eq 0 ]; then
                echo "$(basename $0): specified container is mounted."
                exit
        fi

        # Delete container directories.
        rm -rf $CONTAINER_DIR/$DIR_WORK \
               $CONTAINER_DIR/$DIR_BASE \
               $CONTAINER_DIR/$DIR_MOUNT \
               $CONTAINER_DIR/$DIR_ROOTFS \
               $CONTAINER_DIR

        # Notify user about successful removal.
        echo "$(basename $0): specified container destroyed."

#-------------------------------------------------------------------------------
# command: mount <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "mount" ]; then

        # Check the number of passed arguments.
        if [ $# -lt 2 ]; then
                echo "$(basename $0): mount <container> [mounts]"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"
        CONTAINER_MOUNTS="$CONTAINER_DIR/$DIR_MOUNT/mnt"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "$(basename $0): specified container does not exist."
                exit
        fi

        # Check if the container is mounted.
        mountpoint -q $CONTAINER_DIR/$DIR_MOUNT

        if [ $? -eq 0 ]; then
                echo "$(basename $0): specified container is mounted."
                exit
        fi

        # Mount the container on top of its base.
        mount -t overlay overlay \
              -o lowerdir=$CONTAINER_DIR/$DIR_BASE,upperdir=$CONTAINER_DIR/$DIR_ROOTFS,workdir=$CONTAINER_DIR/$DIR_WORK \
              $CONTAINER_DIR/$DIR_MOUNT

        # Mount the additional directories.
        for DIRECTORY in ${@:3}; do
            if [ ! -d $DIRECTORY ]; then
                echo "$(basename $0): $(basename $DIRECTORY) does not exist. Skipping..."
                continue
            fi

            if [ -d $CONTAINER_MOUNTS/$(basename $DIRECTORY) ]; then
                echo "$(basename $0): $(basename $DIRECTORY) already created. Skipping..."
                continue
            fi

            mkdir -p $CONTAINER_MOUNTS/$(basename $DIRECTORY)
            mount -o bind $DIRECTORY $CONTAINER_MOUNTS/$(basename $DIRECTORY)

            echo "$(basename $0): $(basename $DIRECTORY) mounted."
        done

        # Enable remote access to the window server.
        xhost +local: > /dev/null

        # Notify user about successful mount.
        echo "$(basename $0): specified container mounted."

#-------------------------------------------------------------------------------
# command: umount <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "umount" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "$(basename $0): umount <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"
        CONTAINER_MOUNTS="$CONTAINER_DIR/$DIR_MOUNT/mnt"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "$(basename $0): specified container does not exist."
                exit
        fi

        # Check if the container is mounted.
        mountpoint -q $CONTAINER_DIR/$DIR_MOUNT

        if [ $? -ne 0 ]; then
                echo "$(basename $0): specified container is not mounted."
                exit
        fi

        # Check if the container is booted up.
        machinectl --quiet show $CONTAINER_NAME > /dev/null 2>&1

        if [ $? -eq 0 ]; then
                echo "$(basename $0): specified container is booted up."
                exit
        fi

        # Umount the additional mounts.
        for DIRECTORY in $(find $CONTAINER_MOUNTS -mindepth 1 -maxdepth 1 -type d); do
            mountpoint -q $DIRECTORY

            if [ $? -eq 0 ]; then
                umount $DIRECTORY
                rm -rf $DIRECTORY

                echo "$(basename $0): $(basename $DIRECTORY) unmounted."
            fi
        done

        # Umount the container.
        umount -R $CONTAINER_DIR/$DIR_MOUNT

        # Notify user about successful umount.
        echo "$(basename $0): specified container unmounted."

#-------------------------------------------------------------------------------
# command: boot <container>
#-------------------------------------------------------------------------------
elif [ "$1" = "boot" ]; then

        # Check the number of passed arguments.
        if [ $# -ne 2 ]; then
                echo "$(basename $0): boot <container>"
                exit
        fi

        # Check if the container directory exists.
        CONTAINER_NAME="$2"
        CONTAINER_DIR="$APP_CONTAINERS_DIR/$CONTAINER_NAME"

        if [ ! -d $CONTAINER_DIR ]; then
                echo "$(basename $0): specified container does not exist."
                exit
        fi

        # Check if the container is mounted.
        mountpoint -q $CONTAINER_DIR/$DIR_MOUNT

        if [ $? -ne 0 ]; then
                echo "$(basename $0): specified container is not mounted."
                exit
        fi

        # Check if the container is booted up.
        machinectl --quiet show $CONTAINER_NAME > /dev/null 2>&1

        if [ $? -eq 0 ]; then
                echo "$(basename $0): specified container is booted up."
                exit
        fi

        # Boot the container.
        nohup systemd-nspawn \
                --boot \
                --network-veth \
                --bind /dev/dri \
                --bind /dev/snd \
                --bind /dev/bus/usb \
                --bind-ro /tmp/.X11-unix/X0 \
                --property DeviceAllow="char-drm rwm" \
                --property DeviceAllow="char-alsa rwm" \
                --property DeviceAllow="char-usb_device rwm" \
                --directory $CONTAINER_DIR/$DIR_MOUNT \
                --machine $CONTAINER_NAME \
                > /dev/null 2>&1 &

        # Notify user about successful boot.
        echo "$(basename $0): specified container booted."
#-------------------------------------------------------------------------------
# help
#-------------------------------------------------------------------------------
else
        echo -e "$(basename $0) <command>\n\n" \
                "Commands:\n" \
                "- list $COLOR_GRAY: lists containers and their base.$COLOR_DEFAULT\n" \
                "- download $COLOR_GRAY: download specified base.$COLOR_DEFAULT\n" \
                "- update $COLOR_GRAY: update a specified base.$COLOR_DEFAULT\n" \
                "- create $COLOR_GRAY: creates an empty container of specified name.$COLOR_DEFAULT\n" \
                "- destroy $COLOR_GRAY: destroys specified container and deletes its files.$COLOR_DEFAULT\n" \
                "- mount $COLOR_GRAY: mounts the specified container.$COLOR_DEFAULT\n" \
                "- umount $COLOR_GRAY: unmounts the specified container.$COLOR_DEFAULT\n" \
                "- boot $COLOR_GRAY: boots the specified container in the background.$COLOR_DEFAULT\n"
fi
