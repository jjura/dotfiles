#!/bin/bash

BIN="$HOME/.local/bin/sandbox-overlay"
DIR="$HOME/.local/share/sandbox/containers"

CONTAINERS=$(ls $DIR)
CONTAINERS_AMOUNT=$(echo "$CONTAINERS" | wc -l)

for CONTAINER in $CONTAINERS; do
        BASE=$(basename $(readlink $DIR/$CONTAINER/base))
        OUTPUT="${OUTPUT}$CONTAINER [ $BASE ]\n"
done

CONTAINER=$(echo -e "$OUTPUT" | dmenu -l $CONTAINERS_AMOUNT -p "Container:" | awk -F ' ' '{ print $1 }')

if [ ! -z $CONTAINER ]; then
        COMMAND="sudo $BIN \
                --container-mount $CONTAINER \
                --container-boot $CONTAINER \
                --container-umount $CONTAINER"

        st -e bash -c "$COMMAND"
fi
